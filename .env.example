# Base de donnees PostgreSQL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://niresse:niresse_dev@localhost:5433/niressehouse

# Compte super_admin cree par le seed Prisma
# Email fixe dans prisma/seed.ts, mot de passe lu depuis cette variable
SEED_ADMIN_PASSWORD=ChangeMe123!

# Configuration serveur
NODE_ENV=development

# Authentification
SESSION_SECRET=change_me_in_production
JWT_SECRET=change_me_in_production

# Informations entreprise (affichees dans le frontend)
NEXT_PUBLIC_COMPANY_NAME=NiresseHouse
NEXT_PUBLIC_COMPANY_PHONE=0166369842
NEXT_PUBLIC_COMPANY_EMAIL=niressedigital@gmail.com
NEXT_PUBLIC_COMPANY_WEBSITE=https://niressehouse.com

# Pagination
ITEMS_PER_PAGE=12

# SMTP (a configurer quand on activera les notifications email)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

